# Copy this file to .env and fill in your values
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Database (leave blank to use local SQLite)
# DATABASE_URL=sqlite:///school.db
# For Render PostgreSQL: DATABASE_URL=postgresql://user:pass@host/dbname

# Optional: School details
SCHOOL_NAME=Chandrabhan Singh Public School
ACADEMIC_YEAR=2025-26

# Alert threshold (avg pillar score below this triggers a flag)
ALERT_THRESHOLD=2.0
